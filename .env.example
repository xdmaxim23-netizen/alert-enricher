# Alertmanager
ALERTMANAGER_URL=http://alertmanager:9093

# OpenSearch
OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_USER=
OPENSEARCH_PASS=
OPENSEARCH_INDEX=logs-*
OPENSEARCH_HOST_FIELD=host.keyword

# Log correlation
JANELA_MINUTOS=10
MAX_LOGS=10

# AI API (use mock-ai for testing)
AI_API_URL=http://mock-ai:5002/analyze
AI_TIMEOUT=15

# Telegram
TELEGRAM_TOKEN=your-bot-token-here
TELEGRAM_INFRA_HOT=your-chat-id
TELEGRAM_INFRA_WARM=your-chat-id
TELEGRAM_DEV_HOT=your-chat-id
TELEGRAM_DEV_WARM=your-chat-id
